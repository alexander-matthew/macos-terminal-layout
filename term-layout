# ANSI Escape Sequences for beautiful terminal output
class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'

def print_err(msg):
    print(f"{Colors.FAIL}Error:{Colors.ENDC} {msg}", file=sys.stderr)

def print_info(msg):
    print(f"{Colors.BLUE}Info:{Colors.ENDC} {msg}")

def print_success(msg):
    print(f"{Colors.GREEN}Success:{Colors.ENDC} {msg}")

def run_applescript(script_code):
    """Executes AppleScript code via osascript and returns stdout."""
    try:
        process = subprocess.Popen(
            ['osascript', '-'],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True
        )
        stdout, stderr = process.communicate(script_code)
        if process.returncode != 0:
            raise Exception(stderr.strip())
        return stdout
    except Exception as e:
        print_err(f"Failed to run AppleScript: {e}")
        sys.exit(1)

def get_screen_info():
    """Returns usable screen coordinates (left, top, width, height) in pixels."""
    script = """use AppleScript version "2.4"
use framework "Foundation"
use framework "AppKit"
use scripting additions

set mainScreen to current application's NSScreen's mainScreen()
set screenFrame to mainScreen's frame()
set visibleFrame to mainScreen's visibleFrame()

set H to item 2 of (item 2 of screenFrame)
set vx to item 1 of (item 1 of visibleFrame)
set vy to item 2 of (item 1 of visibleFrame)
set vw to item 1 of (item 2 of visibleFrame)
set vh to item 2 of (item 2 of visibleFrame)

set Usable_Left to vx
set Usable_Top to H - (vy + vh)
set Usable_Width to vw
set Usable_Height to vh

return (Usable_Left as string) & "," & (Usable_Top as string) & "," & (Usable_Width as string) & "," & (Usable_Height as string)
"""
    output = run_applescript(script).strip()
    return list(map(float, output.split(',')))

def load_config():
    """Loads layouts from config file, initializing defaults if missing."""
    if not os.path.exists(CONFIG_PATH):
        os.makedirs(CONFIG_DIR, exist_ok=True)
        with open(CONFIG_PATH, 'w') as f:
            json.dump(DEFAULT_LAYOUTS, f, indent=4)
        return DEFAULT_LAYOUTS
    
    try:
        with open(CONFIG_PATH, 'r') as f:
            return json.load(f)
    except json.JSONDecodeError as e:
        print_err(f"Config file JSON is corrupted: {e}\nLocation: {CONFIG_PATH}")
        sys.exit(1)

def save_config(config):
    """Saves layouts configuration back to file."""
    try:
        os.makedirs(CONFIG_DIR, exist_ok=True)
        with open(CONFIG_PATH, 'w') as f:
            json.dump(config, f, indent=4)
    except Exception as e:
        print_err(f"Failed to save configuration: {e}")
        sys.exit(1)

def cmd_list(config):
    """Lists all configured layout profiles."""
    layouts = config.get("layouts", {})
    if not layouts:
        print_info("No terminal layouts configured.")
        return

    print(f"{Colors.BOLD}{Colors.HEADER}Available Terminal Layouts:{Colors.ENDC}\n")
    for name, windows in layouts.items():
        count = len(windows)
        suffix = "terminal" if count == 1 else "terminals"
        print(f"  • {Colors.CYAN}{Colors.BOLD}{name:<15}{Colors.ENDC} ({count} {suffix})")
    print(f"\nApply a layout with: {Colors.BOLD}term-layout apply <name>{Colors.ENDC}")

def cmd_show(config, name):
    """Displays raw JSON of layout."""
    layouts = config.get("layouts", {})
    if name not in layouts:
        print_err(f"Layout '{name}' not found.")
        sys.exit(1)
    print(json.dumps(layouts[name], indent=4))

def cmd_remove(config, name):
    """Removes a layout profile."""
    layouts = config.get("layouts", {})
    if name not in layouts:
        print_err(f"Layout '{name}' not found.")
        sys.exit(1)
    
    del layouts[name]
    save_config(config)
    print_success(f"Layout '{name}' removed successfully.")

def cmd_save(config, name):
    """Captures current Terminal.app layout and normalizes bounds to fractions."""
    print_info("Querying active macOS Terminal windows...")
    
    script = """use AppleScript version "2.4"
use framework "Foundation"
use framework "AppKit"
use scripting additions

set mainScreen to current application's NSScreen's mainScreen()
set screenFrame to mainScreen's frame()
set visibleFrame to mainScreen's visibleFrame()

set H to item 2 of (item 2 of screenFrame)
set vx to item 1 of (item 1 of visibleFrame)
set vy to item 2 of (item 1 of visibleFrame)
set vw to item 1 of (item 2 of visibleFrame)
set vh to item 2 of (item 2 of visibleFrame)

set Usable_Left to vx
set Usable_Top to H - (vy + vh)
set Usable_Width to vw
set Usable_Height to vh

tell application "Terminal"
    set winList to every window
    set output to (Usable_Left as string) & "," & (Usable_Top as string) & "," & (Usable_Width as string) & "," & (Usable_Height as string) & linefeed
    repeat with w in winList
        set b to bounds of w
        set p to name of current settings of first tab of w
        set output to output & (item 1 of b) & "," & (item 2 of b) & "," & (item 3 of b) & "," & (item 4 of b) & "," & p & linefeed
    end repeat
    return output
end tell
"""
    output = run_applescript(script).strip()
    lines = output.split('\n')
    
    if len(lines) <= 1:
        print_err("No open Terminal.app windows detected to capture.")
        sys.exit(1)
    
    # Line 0: Screen usable boundaries
    ul, ut, uw, uh = map(float, lines[0].split(','))
    if uw <= 0 or uh <= 0:
        print_err("Could not retrieve screen dimensions.")
        sys.exit(1)

    captured_windows = []
    
    for line in lines[1:]:
        parts = line.split(',')
        if len(parts) < 5:
            continue
        w_left = float(parts[0])
        w_top = float(parts[1])
        w_right = float(parts[2])
        w_bottom = float(parts[3])
        profile = ','.join(parts[4:]) # In case profile name has commas
        
        # Convert absolute coordinates to proportional fractions relative to usable screen area
        rel_left = (w_left - ul) / uw
        rel_top = (w_top - ut) / uh
        rel_right = (w_right - ul) / uw
        rel_bottom = (w_bottom - ut) / uh
        
        captured_windows.append({
            "left": round(rel_left, 4),
            "top": round(rel_top, 4),
            "right": round(rel_right, 4),
            "bottom": round(rel_bottom, 4),
            "profile": profile
        })
    
    # Save to config
    config.setdefault("layouts", {})[name] = captured_windows
    save_config(config)
    print_success(f"Captured current screen dimensions ({int(uw)}x{int(uh)})")
    print_success(f"Layout '{name}' ({len(captured_windows)} windows) saved successfully to config!")

def cmd_apply(config, name, close_others=False):
    """Applies a layout profile, scaling fractions to the current screen size."""
    layouts = config.get("layouts", {})
    if name not in layouts:
        print_err(f"Layout '{name}' not found.")
        print(f"Run {Colors.BOLD}term-layout list{Colors.ENDC} to see available options.")
        sys.exit(1)
    
    windows = layouts[name]
    if not windows:
        print_err(f"Layout '{name}' has no windows configured.")
        sys.exit(1)
        
    print_info(f"Applying layout '{name}'...")
    
    # Get current screen coordinates
    ul, ut, uw, uh = get_screen_info()
    
    # Generate AppleScript to arrange windows
    applescript_parts = [
        'use AppleScript version "2.4"',
        'use framework "Foundation"',
        'use framework "AppKit"',
        'use scripting additions',
        '',
        'tell application "Terminal"',
        '    activate',
        '    set existingWindows to every window',
        '    set currentWindow to missing value',
        '    set hasCurrent to false',
        '    if (count of existingWindows) > 0 then',
        '        set currentWindow to front window',
        '        set hasCurrent to true',
        '    end if'
    ]
    
    reused_win = None
    
    for i, win in enumerate(windows):
        w_left = int(ul + win['left'] * uw)
        w_top = int(ut + win['top'] * uh)
        w_right = int(ul + win['right'] * uw)
        w_bottom = int(ut + win['bottom'] * uh)
        profile = win['profile']
        
        # Make sure "Clear Dark" or specified profile is available
        # Reuse frontmost window for the first pane
        if i == 0:
            applescript_parts.extend([
                '    if hasCurrent then',
                f'        set bounds of currentWindow to {{{w_left}, {w_top}, {w_right}, {w_bottom}}}',
                '        try',
                f'            set current settings of first tab of currentWindow to settings set "{profile}"',
                '        end try',
                '    else',
                '        set newTab to do script ""',
                '        set win0 to first window whose tabs contains newTab',
                f'        set bounds of win0 to {{{w_left}, {w_top}, {w_right}, {w_bottom}}}',
                '        try',
                f'            set current settings of newTab to settings set "{profile}"',
                '        end try',
                '    end if'
            ])
        else:
            applescript_parts.extend([
                '    set newTab to do script ""',
                f'    set win{i} to first window whose tabs contains newTab',
                f'    set bounds of win{i} to {{{w_left}, {w_top}, {w_right}, {w_bottom}}}',
                '    try',
                f'        set current settings of newTab to settings set "{profile}"',
                '    end try'
            ])
            
    if close_others:
        applescript_parts.extend([
            '    if closeOthers then', # wait, closeOthers variable from python
            '    end if'
        ])
        # Simple implementation: close other windows
        applescript_parts.extend([
            '    if hasCurrent then',
            '        repeat with w in existingWindows',
            '            if w is not currentWindow then',
            '                try',
            '                    close w saving no',
            '                end try',
            '            end if',
            '        end repeat',
            '    end if'
        ])
        
    applescript_parts.append('end tell')
    
    script_code = '\n'.join(applescript_parts)
    run_applescript(script_code)
    print_success(f"Layout '{name}' applied successfully.")

def cmd_edit():
    """Opens the config file in editor."""
    editor = os.environ.get("EDITOR", "nano")
    print_info(f"Opening config file in {editor}...")
    try:
        subprocess.run([editor, CONFIG_PATH], check=True)
    except Exception as e:
        print_err(f"Could not open editor: {e}")
        print(f"You can edit the config manually at: {CONFIG_PATH}")

def run_interactive(config):
    """Runs interactive setup selection."""
    layouts = config.get("layouts", {})
    if not layouts:
        print_err("No layouts found in config file.")
        sys.exit(1)
        
    print("===========================================")
    print(f"       {Colors.BOLD}{Colors.HEADER}Terminal Layout CLI Manager{Colors.ENDC}")
    print("===========================================")
    print("Select a layout profile to apply:")
    
    layout_names = list(layouts.keys())
    for idx, name in enumerate(layout_names, 1):
        count = len(layouts[name])
        suffix = "terminal" if count == 1 else "terminals"
        print(f"  {idx}) {Colors.CYAN}{name:<15}{Colors.ENDC} ({count} {suffix})")
    print(f"  {len(layout_names) + 1}) Cancel")
    print("-------------------------------------------")
    
    try:
        choice = input(f"Enter choice [1-{len(layout_names) + 1}]: ").strip()
        if not choice:
            print("Operation cancelled.")
            return
            
        choice_idx = int(choice)
        if choice_idx == len(layout_names) + 1:
            print("Operation cancelled.")
            return
            
        if 1 <= choice_idx <= len(layout_names):
            layout_name = layout_names[choice_idx - 1]
        else:
            print_err("Invalid selection.")
            return
            
        clean_choice = input("Would you like to close other open terminal windows first? (y/N): ").strip().lower()
        close_others = clean_choice in ['y', 'yes']
        
        cmd_apply(config, layout_name, close_others)
    except (ValueError, KeyboardInterrupt, EOFError):
        print("\nOperation cancelled.")
        sys.exit(0)

def show_help():
    print(f"""{Colors.BOLD}term-layout - Configurable CLI for macOS Terminal.app layouts{Colors.ENDC}

Usage:
  term-layout [command] [args]

Commands:
  apply | go <name> [-c|--clean]  Apply the layout profile (use -c to close others)
  save | add <name>                Capture currently open Terminal windows and save as layout
  remove | rm <name>               Delete a saved layout profile
  list | ls                        List all saved layouts
  show | cat <name>                Display the JSON details of a layout profile
  edit                             Open the configuration file in your default editor
  help | -h | --help               Show this help message

Options:
  -c, --clean                      When applying, close all other Terminal windows first

If no command is provided, the CLI will run in interactive menu mode.
""")

def main():
    config = load_config()
    
    if len(sys.argv) < 2:
        run_interactive(config)
        return

    cmd = sys.argv[1].lower()
    
    if cmd in ['help', '-h', '--help']:
        show_help()
    elif cmd in ['list', 'ls']:
        cmd_list(config)
    elif cmd == 'edit':
        cmd_edit()
    elif cmd in ['show', 'cat']:
        if len(sys.argv) < 3:
            print_err("Missing layout name. Usage: term-layout show <name>")
            sys.exit(1)
        cmd_show(config, sys.argv[2])
    elif cmd in ['remove', 'rm']:
        if len(sys.argv) < 3:
            print_err("Missing layout name. Usage: term-layout remove <name>")
            sys.exit(1)
        cmd_remove(config, sys.argv[2])
    elif cmd in ['save', 'add']:
        if len(sys.argv) < 3:
            print_err("Missing layout name. Usage: term-layout save <name>")
            sys.exit(1)
        cmd_save(config, sys.argv[2])
    elif cmd in ['apply', 'go']:
        if len(sys.argv) < 3:
            print_err("Missing layout name. Usage: term-layout apply <name> [-c|--clean]")
            sys.exit(1)
        name = sys.argv[2]
        close_others = False
        if len(sys.argv) > 3:
            close_others = sys.argv[3] in ['-c', '--clean']
        cmd_apply(config, name, close_others)
    else:
        # Fallback to apply if command matches a layout directly
        # E.g. `term-layout vertical` instead of `term-layout apply vertical`
        layouts = config.get("layouts", {})
        if cmd in layouts:
            name = cmd
            close_others = False
            if len(sys.argv) > 2:
                close_others = sys.argv[2] in ['-c', '--clean']
            cmd_apply(config, name, close_others)
        else:
            print_err(f"Unknown command or layout: '{cmd}'")
            show_help()
            sys.exit(1)

if __name__ == '__main__':
    main()
